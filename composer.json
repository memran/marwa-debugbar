{
    "name": "memran/marwa-debugbar",
    "description": "A lightweight, framework-agnostic PHP debug bar with profiling capabilities",
    "type": "library",
    "license": "MIT",
    "keywords": ["debug", "profiler", "debugbar", "debugging", "performance"],
    "authors": [
        {
            "name": "Mohammad Emran",
            "email": "memran.dhk@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "memran/marwa-support": "^1.0",
        "psr/log": "^1.1 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "memran/marwa-logger": "^1.0",
        "mockery/mockery": "^1.4",
        "phpstan/phpstan": "^1.4",
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.6",
        "symfony/var-dumper": "^5.3"
    },
    "suggest": {
        "symfony/var-dumper": "For enhanced variable dumping capabilities",
        "psr/log": "To integrate with PSR-3 compatible loggers",
        "monolog/monolog": "For advanced logging integration",
        "twig/twig": "To use the optional Twig dump extension"
    },
    "autoload": {
        "psr-4": {
            "Marwa\\DebugBar\\": "src/"
        },
        "files": ["src/Helpers.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "Marwa\\DebugBar\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text",
        "analyse": "phpstan analyse --no-progress --debug --memory-limit=1G",
        "analyze": "@analyse",
        "lint": "phpcs -n",
        "fix": "phpcbf",
        "ci": [
            "@lint",
            "@test",
            "@analyse"
        ],
        "post-install-cmd": [
            "@composer dump-autoload -o"
        ],
        "post-update-cmd": [
            "@composer dump-autoload -o"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}
