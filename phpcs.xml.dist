<?xml version="1.0"?>
<ruleset name="Marwa DebugBar">
  <description>Project coding standard for source, tests, and examples.</description>

  <rule ref="PSR12"/>
  <exclude name="Generic.Files.LineLength"/>

  <file>src</file>
  <file>tests</file>
  <file>example</file>

  <arg name="basepath" value="."/>
  <arg name="colors"/>
  <arg value="sp"/>
</ruleset>
